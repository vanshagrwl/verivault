# MongoDB
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/<dbname>
DB_NAME=verivault

# Admin account (created on first run if not present)
ADMIN_EMAIL=admin@verivault.com
ADMIN_PASSWORD=change_me_secure

# Brevo / SMTP
BREVO_SMTP_HOST=smtp-relay.sendinblue.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=xsmtp_your_user
BREVO_SMTP_PASS=xsmtp_your_pass
FROM_EMAIL=no-reply@yourdomain.com

# App
PORT=8787
NODE_ENV=production
CORS_ORIGIN=https://your-frontend-url.com
# Brevo (Sendinblue) SMTP settings for sending verification emails
BREVO_SMTP_HOST=smtp-relay.sendinblue.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your_smtp_user
BREVO_SMTP_PASS=your_smtp_password
FROM_EMAIL=no-reply@yourdomain.com

# Optional: adjust default admin credentials for local dev
ADMIN_EMAIL=admin@verivault.com
ADMIN_PASSWORD=admin123

# MongoDB (if not using in-memory dev DB)
# MONGODB_URI=mongodb://user:pass@host:port/dbname
